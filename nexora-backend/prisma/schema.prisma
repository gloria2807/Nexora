// Nexora — Prisma Schema
// Provider is hardcoded to "postgresql" for Render deployment.
// For local development with SQLite, see the LOCAL DEVELOPMENT note below.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// LOCAL DEVELOPMENT NOTE:
// For local SQLite, you have two options:
//
// Option A (recommended) — use a local PostgreSQL via Docker:
//   docker run --name nexora-pg -e POSTGRES_PASSWORD=nexora -e POSTGRES_DB=nexora -p 5432:5432 -d postgres
//   DATABASE_URL="postgresql://postgres:nexora@localhost:5432/nexora"
//
// Option B — temporarily swap provider back to "sqlite" locally:
//   Change provider to "sqlite" and DATABASE_URL to "file:./dev.db"
//   Do NOT commit this change.
// ─────────────────────────────────────────────────────────────────

model Merchant {
  id               String   @id @default(uuid())
  name             String
  email            String
  apiKey           String   @unique
  webhookSecret    String
  nombaAccountId   String
  merchantBalance  Float    @default(0)
  createdAt        DateTime @default(now())

  settlements      Settlement[]
  services         MerchantService[]
}

model Customer {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String   @unique
  phone       String
  bvn         String?
  kycTier     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  virtualAccounts VirtualAccount[]
  invoices        Invoice[]
}

model VirtualAccount {
  id                   String   @id @default(uuid())
  accountName          String
  accountRef           String   @unique
  accountNumber        String?
  bankName             String   @default("Nombank MFB")
  bankAccountName      String?
  status               String   @default("ACTIVE")
  balance              Float    @default(0)
  expectedAmount       Float?
  nombaAccountHolderId String?
  subAccountId         String?

  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  Transaction[]
  ledgerEntries LedgerEntry[]
}

model Invoice {
  id          String   @id @default(uuid())
  reference   String   @unique
  amount      Float
  amountPaid  Float    @default(0)
  status      String   @default("PENDING")
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  transactions Transaction[]
}

model Transaction {
  id               String    @id @default(uuid())
  reference        String    @unique
  nombaRequestId   String?   @unique
  nombaSessionId   String?
  amount           Float
  senderName       String?
  senderAccount    String?
  narration        String?
  status           String    @default("PENDING")
  reconciledAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  virtualAccountId String
  virtualAccount   VirtualAccount @relation(fields: [virtualAccountId], references: [id])

  invoiceId        String?
  invoice          Invoice?  @relation(fields: [invoiceId], references: [id])

  exception        Exception?
  ledgerEntries    LedgerEntry[]
}

model Exception {
  id            String    @id @default(uuid())
  type          String
  reason        String
  amount        Float
  senderName    String?
  resolved      Boolean   @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime  @default(now())

  transactionId String    @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model LedgerEntry {
  id               String   @id @default(uuid())
  type             String
  amount           Float
  balanceAfter     Float
  description      String
  createdAt        DateTime @default(now())

  virtualAccountId String
  virtualAccount   VirtualAccount @relation(fields: [virtualAccountId], references: [id])

  transactionId    String?
  transaction      Transaction? @relation(fields: [transactionId], references: [id])
}

model MerchantService {
  id          String   @id @default(uuid())
  type        String
  destination String
  amount      Float
  status      String   @default("PENDING")
  reference   String   @unique
  nombaRef    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
}

model Settlement {
  id         String   @id @default(uuid())
  amount     Float
  status     String   @default("COMPLETED")
  reference  String   @unique
  createdAt  DateTime @default(now())

  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  requestId   String    @unique
  event       String
  payload     String
  signature   String
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
}
